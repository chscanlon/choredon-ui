{
    "name": "choredon/ui",
    "description": "Choredon design system: tokens, components, and Filament theme.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Choredon\\Ui\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Choredon\\Ui\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/choredon-compile"
    ],
    "extra": {
        "branch-alias": {
            "dev-main": "0.3.x-dev"
        },
        "laravel": {
            "providers": [
                "Choredon\\Ui\\UiServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
