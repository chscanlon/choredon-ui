{
  "$meta": {
    "theme": "choredon",
    "version": "0.1.0",
    "description": "Default Choredon theme. Values source of truth; compiled to CSS custom properties and Tailwind preset."
  },

  "palette": {
    "wingbase": "#0A0D14",
    "deep":     "#0E5F82",
    "triangle": "#1E8FB8",
    "iridescent": "#3DB5DC",
    "underspot": "#B8243C",
    "vellum":   "#EAE2D3",

    "derived": {
      "wingbase-soft":    "#151925",
      "vellum-raised":    "#F2ECE0",
      "vellum-sunk":      "#DDD3BF",
      "triangle-muted":   "#4A9FBD",
      "underspot-soft":   "#D9506A",
      "ink":              "#1A1F2B",
      "ink-muted":        "#4B5362",
      "ink-subtle":       "#7A8192",
      "line":             "#C7BFAE",
      "line-subtle":      "#DDD3BF"
    },

    "_neutral-comment": "Warm-neutral ramp. Anchored by Vellum at 50 and Wingbase-ink at 950. Replaces Tailwind zinc in Flux and Filament adapters so every non-accent surface/border/text in those frameworks picks up Choredon's warm tonal direction. Not a brand primitive; derived for systems integration.",

    "neutral": {
      "50":  "#F5EFE3",
      "100": "#EAE2D3",
      "200": "#DDD3BF",
      "300": "#C7BFAE",
      "400": "#9E968A",
      "500": "#7A7267",
      "600": "#5A5347",
      "700": "#403A2F",
      "800": "#2B2721",
      "900": "#1A1815",
      "950": "#0F0E0C"
    }
  },

  "semantic": {
    "color": {
      "surface": {
        "base":    "{palette.vellum}",
        "raised":  "{palette.derived.vellum-raised}",
        "sunk":    "{palette.derived.vellum-sunk}",
        "inverse": "{palette.wingbase}",
        "inverse-raised": "{palette.derived.wingbase-soft}"
      },
      "text": {
        "primary":   "{palette.derived.ink}",
        "secondary": "{palette.derived.ink-muted}",
        "tertiary":  "{palette.derived.ink-subtle}",
        "on-inverse": "{palette.vellum}",
        "on-primary": "{palette.vellum}",
        "on-accent":  "#FFFFFF",
        "link":       "{palette.deep}",
        "link-hover": "{palette.triangle}"
      },
      "border": {
        "subtle":   "{palette.derived.line-subtle}",
        "default":  "{palette.derived.line}",
        "strong":   "{palette.derived.ink-muted}",
        "focus":    "{palette.triangle}"
      },
      "interactive": {
        "primary":          "{palette.triangle}",
        "primary-hover":    "{palette.deep}",
        "primary-active":   "{palette.deep}",
        "primary-disabled": "{palette.derived.triangle-muted}",
        "secondary":        "{palette.wingbase}",
        "secondary-hover":  "{palette.derived.wingbase-soft}",
        "ghost-hover-bg":   "{palette.derived.vellum-sunk}"
      },
      "feedback": {
        "critical":        "{palette.underspot}",
        "critical-soft":   "{palette.derived.underspot-soft}",
        "success":         "#2E7D4F",
        "warning":         "#B37A1E",
        "info":            "{palette.deep}"
      },
      "focus-ring": "{palette.triangle}"
    },

    "font": {
      "display": "'Fraunces', ui-serif, Georgia, serif",
      "ui":      "'Inter Tight', ui-sans-serif, system-ui, sans-serif",
      "mono":    "ui-monospace, 'SF Mono', 'JetBrains Mono', Menlo, monospace"
    },

    "font-weight": {
      "regular":  "400",
      "medium":   "500",
      "semibold": "600",
      "bold":     "700"
    },

    "type-scale": {
      "_comment": "Fluid scale using clamp(min, preferred-vw, max). 16px base, 1.25 ratio. Min = mobile floor (375px vw), max = desktop ceiling (1440px vw).",

      "caption":  { "size": "clamp(0.75rem, 0.72rem + 0.15vw, 0.8125rem)",  "line-height": "1.45", "letter-spacing": "0.01em" },
      "body-sm":  { "size": "clamp(0.8125rem, 0.8rem + 0.15vw, 0.875rem)",  "line-height": "1.55", "letter-spacing": "0" },
      "body":     { "size": "clamp(0.9375rem, 0.9rem + 0.2vw, 1rem)",       "line-height": "1.6",  "letter-spacing": "0" },
      "body-lg":  { "size": "clamp(1rem, 0.95rem + 0.25vw, 1.125rem)",      "line-height": "1.6",  "letter-spacing": "0" },
      "heading-6": { "size": "clamp(1rem, 0.95rem + 0.25vw, 1.125rem)",     "line-height": "1.4",  "letter-spacing": "0",       "weight": "500" },
      "heading-5": { "size": "clamp(1.125rem, 1.05rem + 0.35vw, 1.25rem)",  "line-height": "1.35", "letter-spacing": "0",       "weight": "500" },
      "heading-4": { "size": "clamp(1.25rem, 1.15rem + 0.5vw, 1.5rem)",     "line-height": "1.3",  "letter-spacing": "-0.005em","weight": "500" },
      "heading-3": { "size": "clamp(1.5rem, 1.3rem + 0.8vw, 1.875rem)",     "line-height": "1.25", "letter-spacing": "-0.01em", "weight": "500" },
      "heading-2": { "size": "clamp(1.875rem, 1.5rem + 1.5vw, 2.5rem)",     "line-height": "1.15", "letter-spacing": "-0.015em","weight": "500" },
      "heading-1": { "size": "clamp(2.25rem, 1.75rem + 2.2vw, 3.5rem)",     "line-height": "1.1",  "letter-spacing": "-0.02em", "weight": "500" },
      "display":   { "size": "clamp(2.75rem, 2rem + 3.2vw, 4.5rem)",        "line-height": "1.05", "letter-spacing": "-0.025em","weight": "500" }
    },

    "spacing": {
      "_comment": "8px base with 4px half-step. Fluid scale for section-level. Fixed for component-level.",
      "0":   "0",
      "px":  "1px",
      "0.5": "0.125rem",
      "1":   "0.25rem",
      "1.5": "0.375rem",
      "2":   "0.5rem",
      "3":   "0.75rem",
      "4":   "1rem",
      "5":   "1.25rem",
      "6":   "1.5rem",
      "8":   "2rem",
      "10":  "2.5rem",
      "12":  "3rem",
      "16":  "4rem",
      "20":  "5rem",
      "24":  "6rem",

      "section-sm": "clamp(2rem, 1.5rem + 2vw, 3.5rem)",
      "section":    "clamp(3rem, 2rem + 4vw, 6rem)",
      "section-lg": "clamp(4rem, 2.5rem + 6vw, 9rem)"
    },

    "radius": {
      "_comment": "Restrained. Brand doc's geometric triangle motif rewards crisp corners over soft ones.",
      "none": "0",
      "sm":   "0.125rem",
      "md":   "0.25rem",
      "lg":   "0.5rem",
      "xl":   "0.75rem",
      "pill": "9999px",
      "default": "0.25rem"
    },

    "shadow": {
      "_comment": "Sparingly used. Choredon's beauty-first principle favours borders and surface-colour separation over drop shadows.",
      "none":   "none",
      "sm":     "0 1px 2px rgba(10, 13, 20, 0.06)",
      "md":     "0 2px 6px rgba(10, 13, 20, 0.08), 0 1px 2px rgba(10, 13, 20, 0.04)",
      "lg":     "0 8px 24px rgba(10, 13, 20, 0.10), 0 2px 6px rgba(10, 13, 20, 0.06)",
      "focus":  "0 0 0 3px rgba(30, 143, 184, 0.35)"
    },

    "motion": {
      "duration": {
        "instant": "0ms",
        "fast":    "120ms",
        "base":    "200ms",
        "slow":    "320ms"
      },
      "easing": {
        "standard": "cubic-bezier(0.2, 0, 0, 1)",
        "enter":    "cubic-bezier(0, 0, 0, 1)",
        "exit":     "cubic-bezier(0.4, 0, 1, 1)"
      }
    },

    "size": {
      "touch-target":       "2.75rem",
      "control-sm":         "2rem",
      "control":            "2.5rem",
      "control-lg":         "3rem",
      "icon-sm":            "1rem",
      "icon":               "1.25rem",
      "icon-lg":            "1.5rem",
      "max-content":        "72rem",
      "max-prose":          "42rem",
      "max-form":           "28rem"
    },

    "breakpoint": {
      "_comment": "Layout breakpoints only. Type and section spacing are fluid and do not use these.",
      "sm":  "640px",
      "md":  "768px",
      "lg":  "1024px",
      "xl":  "1280px",
      "2xl": "1536px"
    },

    "z-index": {
      "base":    "0",
      "raised":  "10",
      "dropdown":"100",
      "sticky":  "200",
      "overlay": "300",
      "modal":   "400",
      "toast":   "500",
      "tooltip": "600"
    }
  },

  "component": {
    "_comment": "Only populated where semantic tokens aren't expressive enough. Starts empty; grows on demand.",
    "button": {}
  }
}
